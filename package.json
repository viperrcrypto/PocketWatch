{
  "name": "pocketwatch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:backup": "pg_dump pocketwatch > backups/pocketwatch-$(date +%Y%m%d-%H%M%S).sql && echo 'Backup saved to backups/'",
    "db:prepare": "npm run db:backup 2>/dev/null; prisma generate && (prisma migrate deploy || prisma db push)",
    "dev": "npm run db:prepare && pkill -f 'next dev' 2>/dev/null; rm -rf .next && NODE_OPTIONS='--max-old-space-size=4096' next dev --hostname 0.0.0.0 --port 3500",
    "build": "if [ -n \"$DATABASE_MIGRATE_URL\" ]; then prisma db push --accept-data-loss --url \"$DATABASE_MIGRATE_URL\"; fi && prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "npm run db:prepare && next start",
    "lint": "eslint",
    "test": "npm run test:unit",
    "test:unit": "npx tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@codex-data/sdk": "^2.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.90.20",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "ccxt": "^4.5.40",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "facehash": "^0.1.0",
    "graphql": "^16.13.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lightweight-charts": "^5.1.0",
    "marked": "^17.0.5",
    "motion": "^12.38.0",
    "next": "16.1.6",
    "node-cron": "^4.2.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.17.2",
    "plaid": "^41.3.0",
    "pmtiles": "^4.4.0",
    "protomaps-themes-base": "^4.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "torph": "^0.0.5",
    "viem": "^2.45.0",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.3.0",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  }
}
