# Database (PostgreSQL — Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://user:pass@host:5432/pocketwatch"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host:5432/pocketwatch"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Encryption key for API keys stored in DB (32-byte hex string)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# Zerion API (portfolio balance aggregation)
# Get at: https://zerion.io/developers
ZERION_API_KEY=""

# CoinGecko API (token prices)
COINGECKO_API_KEY=""

# Helius API (Solana RPC, tx history, token metadata)
# Get at: https://dev.helius.xyz
HELIUS_API_KEY=""

# Alchemy (EVM RPC provider)
ALCHEMY_API_KEY=""

# WalletConnect project ID (wallet connection)
# Get at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Internal staking snapshot cron auth secret (required for /api/internal/staking/snapshot-hourly)
STAKING_CRON_SECRET=""

# Internal history sync worker auth secret (required for /api/internal/history/sync-worker)
HISTORY_CRON_SECRET=""

# Internal portfolio refresh worker auth secret (required for /api/internal/portfolio/refresh-worker)
PORTFOLIO_REFRESH_CRON_SECRET=""

# Snapshot worker + transaction classifier auth secret (required for /api/internal/snapshot-worker and /api/internal/classify-transactions)
SNAPSHOT_WORKER_SECRET=""

# Travel price-check worker auth secret (required for /api/internal/travel/price-check-worker — the saved-route price-drop cron)
TRAVEL_PRICE_CHECK_SECRET=""

# Daily "Hello Money" finance digest worker auth secret (required for /api/internal/finance-digest-worker)
FINANCE_DIGEST_SECRET=""

# Finance MCP server token (required for /api/mcp — lets Claude Desktop query your
# finances). MUST be 32+ chars; generate with: openssl rand -hex 32. Exposes full
# financial data over the tunnel — pair with Cloudflare Access / IP allowlist.
POCKETWATCH_MCP_TOKEN=""

# Desktop menu-bar app secret (required for /api/internal/desktop-status — the
# Tauri tray's net-worth poller). 32+ chars; set the SAME value in desktop/.
POCKETWATCH_DESKTOP_SECRET=""

# Portfolio refresh + provider governor (correctness-first defaults)
PORTFOLIO_REFRESH_TTL_MS="300000"
ZERION_MIN_INTERVAL_MS="20000"
ALCHEMY_MIN_INTERVAL_MS="500"
CCXT_MIN_INTERVAL_MS="15000"
DEFI_LLAMA_MIN_INTERVAL_MS="1000"
PROVIDER_429_BACKOFF_BASE_MS="60000"
PROVIDER_429_BACKOFF_MAX_MS="900000"

# API key for remote device access (generate: openssl rand -hex 32)
# Share this key with OpenClaw or other clients for programmatic access
POCKETWATCH_API_KEY=""

# Roame Firebase API key (for automatic session refresh)
# This is Roame's public client-side Firebase key
ROAME_FIREBASE_API_KEY=""

# Finance sync worker auth secret (required for /api/internal/finance-sync-worker)
FINANCE_SYNC_SECRET=""

# WeatherAPI key (free) — powers the trip travel-day briefing's destination weather.
# Get a free key at: https://www.weatherapi.com — if unset, the briefing simply omits weather.
WEATHERAPI_KEY=""

# Gmail OAuth connector (read-only mailbox access for the Gmail integration).
# The operator supplies a Google Cloud OAuth *Web* application client (Gmail API
# enabled) and adds the redirect URI below to its authorized redirect URIs.
# Create one at: https://console.cloud.google.com/apis/credentials
# If GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET are unset, the Gmail
# connector is simply unavailable.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3500/api/integrations/gmail/callback"
