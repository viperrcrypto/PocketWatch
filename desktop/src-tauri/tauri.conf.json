{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PocketWatch",
  "version": "0.1.0",
  "identifier": "com.pocketwatch.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PocketWatch",
        "url": "http://localhost:3500",
        "width": 1200,
        "height": 820,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 16, "y": 20 },
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
